{
  "compilerOptions": {
    "target": "esnext",
    "module": "node20",
    "moduleResolution": "node16",
    "outDir": "./dist",
    "rootDir": "./app",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["app/**/*"],
  "exclude": ["node_modules", "dist"]
}
